# ─── LUXORA BACKEND ENV ───────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/luxora_db

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-super-secret-access-key-at-least-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie
COOKIE_SECRET=your-cookie-secret-min-16-chars

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://luxora.in

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=LUXORA <noreply@luxora.in>

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
